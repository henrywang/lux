          }
        },
        "required": ["app_id"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "manage_service",
      "description": "Start, stop, enable, disable, or restart a systemd service",
      "parameters": {
        "type": "object",
        "properties": {
          "service": {
            "type": "string",
            "description": "Service name (e.g. bluetooth, cups, sshd)"
          },
          "action": {
            "type": "string",
            "enum": ["start", "stop", "enable", "disable", "restart"],
            "description": "Action to perform on the service"
          }
        },
        "required": ["service", "action"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "check_service_status",
      "description": "Check the status of a systemd service",
      "parameters": {
        "type": "object",
        "properties": {
          "service": {
            "type": "string",
            "description": "Service name to check"
          }
        },
        "required": ["service"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "read_logs",
      "description": "Read system logs from journalctl, optionally filtered by unit or time",
      "parameters": {
        "type": "object",
        "properties": {
          "unit": {
            "type": "string",
            "description": "Filter logs by systemd unit name"
          },
          "since": {
            "type": "string",
            "description": "Show logs since this time (e.g. '1 hour ago', 'today')"
          },
          "priority": {
            "type": "string",
            "enum": ["emerg", "alert", "crit", "err", "warning", "notice", "info", "debug"],
            "description": "Minimum priority level"
          },
          "lines": {
            "type": "integer",
            "description": "Number of recent lines to return"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "check_disk_usage",
      "description": "Check disk space usage on the system",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Path to check (defaults to /)"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "manage_firewall",
      "description": "Add or remove firewall rules via firewalld",
      "parameters": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["allow", "deny"],
            "description": "Allow or deny traffic"
          },
          "service": {
            "type": "string",
            "description": "Service name (e.g. ssh, http, https)"
          },
          "port": {
            "type": "string",
            "description": "Port/protocol (e.g. '8080/tcp')"
          }
        },
        "required": ["action"]
      }
    }
  },
  {
