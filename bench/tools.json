      "parameters": {
        "type": "object",
        "properties": {
          "packages": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Package names to install"
          }
        },
        "required": ["packages"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "remove_package",
      "description": "Remove a system package",
      "parameters": {
        "type": "object",
        "properties": {
          "packages": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Package names to remove"
          }
        },
        "required": ["packages"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "install_flatpak",
      "description": "Install a desktop application via Flatpak",
      "parameters": {
        "type": "object",
        "properties": {
          "app_id": {
            "type": "string",
